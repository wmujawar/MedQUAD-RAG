# ============================================================
# Python Build Artifacts
# ============================================================
# Compiled bytecode and cache directories generated by Python
__pycache__/
*.py[oc]

# Build output directories (generated by setuptools, pip, etc.)
build/
dist/
wheels/

# Package metadata generated by setuptools
*.egg-info


# ============================================================
# Virtual Environments
# ============================================================
# Local Python virtual environment directory
.venv


# ============================================================
# AI / ML Tool Directories
# ============================================================
# Guardrails AI local config and cache
.guardrails

# DeepEval local config, cache, and test results
.deepeval


# ============================================================
# Logs
# ============================================================
# All log files inside the logs/ directory
logs/*.log


# ============================================================
# Checkpoints
# ============================================================
# Model or training checkpoint files (e.g. checkpoint-100, checkpoint_final)
checkpoint*


# ============================================================
# Editor / IDE Settings
# ============================================================
# Zed editor project-specific settings
.zed/


# ============================================================
# Environment Variables
# ============================================================
# Local environment config — contains secrets, never commit this!
.env

.DS_Store
