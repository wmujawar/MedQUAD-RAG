APP_ENV=staging
EMBEDDING_PROVIDER=github_openai
GENERATION_PROVIDER=github_openai
EMBEDDING_MODEL=text-embedding-3-small
GENERATOR_MODEL=gpt-4o-mini
LLM_PROVIDER_BASE_URL=https://models.inference.ai.azure.com
EMBEDDING_DIM=1536
LOG_LEVEL=DEBUG

# Chunking
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
TOP_K=3
MAX_RETRIEVAL_ITERATIONS=3
RELEVANCY_THRESHOLD=0.7

# Cache / Redis
REDIS_URL=redis://localhost:6380
EMBEDDING_CACHE_TTL=86400

# Vector store
VECTOR_STORE_PROVIDER=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_KEY=your_qdrant_cloud_api_key # Required only when using Qdrant Cloud; leave empty for local Qdrant.
QDRANT_COLLECTION=medquad_documents

# postgres
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_postgres_db

# Langfuse
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=http://localhost:3000
ENCRYPTION_KEY=your_64_char_hex_encryption_key
NEXTAUTH_SECRET=your_nextauth_secret
SALT=your_salt

# clickhouse
CLICKHOUSE_USER=your_clickhouse_user
CLICKHOUSE_PASSWORD=your_clickhouse_password
CLICKHOUSE_DB=default

# MinIO
MINIO_ROOT_USER=your_minio_root_user
MINIO_ROOT_PASSWORD=your_minio_root_password

# Langfuse redis
REDIS_AUTH=your_redis_auth
